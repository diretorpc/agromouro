# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...      # Chave pública — usada no frontend e no middleware de auth
SUPABASE_SERVICE_KEY=eyJhbGc...   # Chave secreta — só usar no backend (nunca expor no frontend)

# ─── Z-API (WHATSAPP) ──────────────────────────────────────────────────────────
# Encontre em: z-api.io → sua instância → Credenciais
ZAPI_INSTANCE_ID=sua-instancia-id
ZAPI_TOKEN=seu-token
ZAPI_PHONE=5554999999999           # Número conectado (com DDI e DDD, sem +)

# ─── ANTHROPIC (CLAUDE) ───────────────────────────────────────────────────────
# Encontre em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── SEFAZ — NF-e ENTRADA (e-CPF A1) ─────────────────────────────────────────
# Converta o .pfx/.p12 para base64: base64 -w 0 certificado.pfx
# O job roda a cada 30min e puxa NF-e emitidas contra o CPF da fazenda
ECPF_CERT_BASE64=base64-do-arquivo-pfx-aqui
ECPF_CERT_PASSWORD=senha-do-certificado

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://agromouro.vercel.app   # URL de produção do frontend no Vercel

# ─── SEGURANÇA — WEBHOOKS ─────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Configure o MESMO valor no painel da Z-API como "webhook secret"
WEBHOOK_SECRET=gere-um-valor-aleatorio-aqui

# ─── (FUTURO) JOHN DEERE ──────────────────────────────────────────────────────
# JD_CLIENT_ID=
# JD_CLIENT_SECRET=
# JD_REDIRECT_URI=

# ─── (FUTURO) PLUGGY / OPEN FINANCE ──────────────────────────────────────────
# PLUGGY_CLIENT_ID=
# PLUGGY_CLIENT_SECRET=

# ─── (FUTURO) SENTINEL HUB (NDVI) ────────────────────────────────────────────
# SENTINELHUB_CLIENT_ID=
# SENTINELHUB_CLIENT_SECRET=
